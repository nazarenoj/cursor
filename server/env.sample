# Opcional: forzar la versión que devuelve la API (por defecto lee public/app-version.json o src/version.ts en dev)
# APP_VERSION=3.5.0

# WhatsApp Baileys: un solo proceso Node (recomendado Hostinger con 1 app)
# WHATSAPP_EMBEDDED=true
# Carpeta persistente para la sesión (si no se define: server/whatsapp_auth relativo al server)
# WHATSAPP_AUTH_FOLDER=C:\ruta\whatsapp_auth

# Modo microservicio aparte (dev:all o segundo proceso): no uses WHATSAPP_EMBEDDED
# WHATSAPP_SERVICE_URL=http://127.0.0.1:4002

# Opcional cola Baileys
# WA_DELAY_MS=5000
# WA_QUEUE_MAX=500
# LOG_LEVEL=info
